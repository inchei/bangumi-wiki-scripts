#!/bin/sh

bump_version() {
  file="$1"
  old_version=$(grep -o '@version\s\+[0-9.]\+' "$file" | awk '{print $2}')
  if [ -z "$old_version" ]; then
    echo "  ⚠ $file: @version not found, skip bump"
    return
  fi
  last=$(echo "$old_version" | rev | cut -d. -f1 | rev)
  prefix=$(echo "$old_version" | sed "s/\.$last$//")
  new_version="${prefix}.$((last + 1))"
  if [ "$OSTYPE" = "darwin"* ]; then
    sed -i '' "s/@version\s\+$old_version/@version      $new_version/" "$file"
  else
    sed -i "s/@version\s\+$old_version/@version      $new_version/" "$file"
  fi
  echo "  🔖 $file: $old_version → $new_version"
}

GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
FE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^bgq/frontend/src/' || true)
MP_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^wikiMissingPositions/src/' || true)
PA_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^wikiPersonAlias/' || true)
WB_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^wikiBatch/src/' || true)

if [ -n "$GO_FILES" ]; then
  gofmt -w $GO_FILES
  git add $GO_FILES
  cd bgq && go vet ./... 2>&1 || exit 1
  golangci-lint run ./... 2>&1 || exit 1
  go test ./internal/query/ -run 'Test[^E]' 2>&1 || exit 1
  cd ..
fi

if [ -n "$FE_FILES" ]; then
  cd bgq/frontend && pnpm exec lint-staged || exit 1
  cd ../..
fi

if [ -n "$MP_FILES" ]; then
  bump_version wikiMissingPositions/header.js
  cd wikiMissingPositions
  if ! (pnpm lint && pnpm lint:css && pnpm format:check && pnpm build); then
    cd ..
    git checkout -- wikiMissingPositions/header.js
    exit 1
  fi
  cd ..
  git add wikiMissingPositions/header.js wikiMissingPositions/dist/wikiMissingPositions.user.js
fi

if [ -n "$PA_FILES" ]; then
  bump_version wikiPersonAlias/wikiPersonAlias.user.js
  cd wikiPersonAlias
  if ! (pnpm lint && pnpm format:check); then
    cd ..
    git checkout -- wikiPersonAlias/wikiPersonAlias.user.js
    exit 1
  fi
  cd ..
  git add wikiPersonAlias/wikiPersonAlias.user.js
fi

if [ -n "$WB_FILES" ]; then
  bump_version wikiBatch/header.js
  cd wikiBatch
  if ! (pnpm lint && pnpm lint:css && pnpm typecheck && pnpm build); then
    cd ..
    git checkout -- wikiBatch/header.js
    exit 1
  fi
  cd ..
  git add wikiBatch/header.js wikiBatch/dist/wikiBatch.user.js
fi
