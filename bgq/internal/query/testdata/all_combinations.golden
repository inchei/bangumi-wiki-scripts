LIMIT 10
character_person_character_all	WITH subjects AS (SELECT * FROM read_json_auto('$DATA_DIR/subject.jsonlines', format='newline_delimited')),
characters AS (SELECT id as character_id, role, name, COALESCE(infobox,'') as infobox, summary, comments, collects FROM read_json_auto('$DATA_DIR/character.jsonlines', format='newline_delimited')),
person_characters AS (SELECT * FROM read_json_auto('$DATA_DIR/person-characters.jsonlines', format='newline_delimited')),
persons AS (SELECT id as person_id, name, type as person_type, career, COALESCE(infobox,'') as infobox, summary FROM read_json_auto('$DATA_DIR/person.jsonlines', format='newline_delimited'))
SELECT c.character_id as id, c.name
FROM characters c
WHERE EXISTS (SELECT 1 FROM person_characters pc WHERE pc.character_id = c.character_id AND pc.type = 0) AND
			 (SELECT COUNT(*) FROM (
			   SELECT pc.person_id FROM person_characters pc 
			   LEFT JOIN subjects rs ON pc.subject_id = rs.id
			   WHERE pc.character_id = c.character_id AND pc.type = 0 AND CAST(rs.score AS DOUBLE) > 8
			   GROUP BY pc.person_id
			 ) t) =
			 (SELECT COUNT(DISTINCT pc.person_id) FROM person_characters pc WHERE pc.character_id = c.character_id AND pc.type = 0)
LIMIT 10
character_person_character_all_subjall	WITH subjects AS (SELECT * FROM read_json_auto('$DATA_DIR/subject.jsonlines', format='newline_delimited')),
characters AS (SELECT id as character_id, role, name, COALESCE(infobox,'') as infobox, summary, comments, collects FROM read_json_auto('$DATA_DIR/character.jsonlines', format='newline_delimited')),
person_characters AS (SELECT * FROM read_json_auto('$DATA_DIR/person-characters.jsonlines', format='newline_delimited')),
persons AS (SELECT id as person_id, name, type as person_type, career, COALESCE(infobox,'') as infobox, summary FROM read_json_auto('$DATA_DIR/person.jsonlines', format='newline_delimited'))
SELECT c.character_id as id, c.name
FROM characters c
WHERE EXISTS (SELECT 1 FROM person_characters pc WHERE pc.character_id = c.character_id AND pc.type = 0) AND
			 NOT EXISTS (
			   SELECT 1 FROM person_characters pc 
			   WHERE pc.character_id = c.character_id AND pc.type = 0
			   AND EXISTS (
			     SELECT 1 FROM person_characters pc2
			     LEFT JOIN subjects rs ON pc2.subject_id = rs.id
			     WHERE pc2.character_id = c.character_id AND pc2.person_id = pc.person_id
			     AND NOT (CAST(rs.score AS DOUBLE) > 8)
			   )
			 )
LIMIT 10
