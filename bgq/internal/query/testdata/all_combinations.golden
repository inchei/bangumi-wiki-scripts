person_character_person_all	WITH subjects AS (SELECT * FROM read_json_auto('$DATA_DIR/subject.jsonlines', format='newline_delimited')),
persons AS (SELECT id as person_id, name, type as person_type, career, COALESCE(infobox,'') as infobox, summary FROM read_json_auto('$DATA_DIR/person.jsonlines', format='newline_delimited')),
person_characters AS (SELECT * FROM read_json_auto('$DATA_DIR/person-characters.jsonlines', format='newline_delimited')),
characters AS (SELECT id as character_id, role, name, COALESCE(infobox,'') as infobox, summary, comments, collects FROM read_json_auto('$DATA_DIR/character.jsonlines', format='newline_delimited'))
SELECT p.person_id as id, p.name
FROM persons p
WHERE EXISTS (SELECT 1 FROM person_characters pc WHERE pc.person_id = p.person_id AND pc.type = 0) AND
			 (SELECT COUNT(*) FROM (
			   SELECT pc.character_id FROM person_characters pc 
			   LEFT JOIN subjects rs ON pc.subject_id = rs.id
			   WHERE pc.person_id = p.person_id AND pc.type = 0 AND CAST(rs.score AS DOUBLE) > 8
			   GROUP BY pc.character_id
			 ) t) =
			 (SELECT COUNT(DISTINCT pc.character_id) FROM person_characters pc WHERE pc.person_id = p.person_id AND pc.type = 0)
LIMIT 10
