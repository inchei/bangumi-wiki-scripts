tag_negate	WITH subjects AS (SELECT * FROM read_json_auto('$DATA_DIR/subject.jsonlines', format='newline_delimited'))
SELECT s.id as id, s.name
FROM subjects s
WHERE NOT EXISTS (SELECT 1 FROM (SELECT UNNEST(s.tags) AS t) WHERE t.name = 'test')
LIMIT 10
tag_subject	WITH subjects AS (SELECT * FROM read_json_auto('$DATA_DIR/subject.jsonlines', format='newline_delimited'))
SELECT s.id as id, s.name
FROM subjects s
WHERE EXISTS (SELECT 1 FROM (SELECT UNNEST(s.tags) AS t) WHERE t.name = 'test')
LIMIT 10
type_character	WITH subjects AS (SELECT * FROM read_json_auto('$DATA_DIR/subject.jsonlines', format='newline_delimited')),
characters AS (SELECT id as character_id, role, name, COALESCE(infobox,'') as infobox, summary, comments, collects FROM read_json_auto('$DATA_DIR/character.jsonlines', format='newline_delimited'))
SELECT c.character_id as id, c.name
FROM characters c
WHERE c.role = 1
LIMIT 10
type_person	WITH subjects AS (SELECT * FROM read_json_auto('$DATA_DIR/subject.jsonlines', format='newline_delimited')),
persons AS (SELECT id as person_id, name, type as person_type, career, COALESCE(infobox,'') as infobox, summary FROM read_json_auto('$DATA_DIR/person.jsonlines', format='newline_delimited'))
SELECT p.person_id as id, p.name
FROM persons p
WHERE p.person_type = 1
LIMIT 10
type_subject	WITH subjects AS (SELECT * FROM read_json_auto('$DATA_DIR/subject.jsonlines', format='newline_delimited'))
SELECT s.id as id, s.name
FROM subjects s
WHERE s.type = 1
LIMIT 10
