{"id":87,"type":1,"name":"合法ドラッグ (1)","name_cn":"","infobox":"{{Infobox animanga/Manga\n|作者= CLAMP\n|出版社= 角川書店\n|发售日= 2001-06-01\n|页数= \n|话数= \n|ISBN= 9784048533416\n|其他= \n|ISBN-10= 404853341X\n}}","platform":1001,"summary":"衝撃のスーパーナチュラル・サスペンス！\n\n　　薬局で居候しながら、バイトする風疾（かざはや）＆陸王（りくおう）。しかし、その薬局には裏の仕事があった！果たして二人の活躍は！?","nsfw":false,"tags":[{"name":"CLAMP","count":36},{"name":"腐","count":20},{"name":"耽美系","count":9},{"name":"擦边球","count":7},{"name":"基","count":4},{"name":"CLMAP","count":4},{"name":"老坑","count":3},{"name":"猫井椿","count":3},{"name":"BL","count":3},{"name":"合法ドラッグ","count":2},{"name":"黑羽快斗","count":1}],"meta_tags":[],"score":7.1,"score_details":{"1":0,"2":0,"3":0,"4":0,"5":2,"6":12,"7":21,"8":13,"9":2,"10":2},"rank":4644,"date":"2001-06-01","favorite":{"wish":25,"done":73,"doing":0,"on_hold":2,"dropped":0},"series":false}
